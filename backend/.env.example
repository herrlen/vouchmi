APP_NAME=TrusCart
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://app.truscart.com
FRONTEND_URL=https://truscart.com

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
