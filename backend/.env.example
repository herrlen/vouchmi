APP_NAME=Vouchmi
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://app.vouchmi.com

APP_LOCALE=de
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=de_DE

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=vouchmi_app
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_DRIVER=file
CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=localhost
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="no-reply@vouchmi.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-central-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Sanctum — app.vouchmi.com serves the API
SANCTUM_STATEFUL_DOMAINS=app.vouchmi.com
SESSION_DOMAIN=.vouchmi.com

# Affiliate partners
AMAZON_PARTNER_TAG=
AWIN_PUBLISHER_ID=
AWIN_API_TOKEN=

# Short-Link-Domain (später auf vouchmi.link umstellen)
SHORT_LINK_DOMAIN=app.vouchmi.com
SHORT_LINK_SCHEME=https

# PayPal
PAYPAL_MODE=live
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_PLAN_ID=                    # Legacy (Bestandskunden 0,99 €)
PAYPAL_PLAN_ID_BRAND=              # Brand-Abo 1,99 €/Monat
PAYPAL_PLAN_ID_INFLUENCER=         # Influencer-Abo 0,99 €/Monat
PAYPAL_WEBHOOK_ID=                 # Webhook für Subscriptions (BILLING.*, PAYMENT.SALE.*)
PAYPAL_WALLET_WEBHOOK_ID=          # Webhook für Wallet-Topups (PAYMENT.CAPTURE.*, CUSTOMER.DISPUTE.*)

# Apple IAP (StoreKit 2 / App Store Server API)
APPLE_IAP_BUNDLE_ID=com.vouchmi.app
APPLE_IAP_ISSUER_ID=                                                # App Store Connect → Users and Access → Keys → Issuer ID
APPLE_IAP_KEY_ID=                                                   # In-App-Käufe-Schlüssel → Key ID (NICHT der App-Store-Connect-API-Key!)
APPLE_IAP_PRIVATE_KEY_PATH=storage/app/private/AuthKey_XXX.p8       # .p8 Datei (chmod 600, NICHT committen)
APPLE_IAP_ENVIRONMENT=sandbox                                       # sandbox | production
APPLE_IAP_ROOT_CA_PATH=storage/app/apple/AppleRootCA-G3.cer
APPLE_IAP_PRODUCT_ID_BRAND_MONTHLY=com.vouchmi.app.brand.monthly
APPLE_IAP_PRODUCT_ID_INFLUENCER_MONTHLY=com.vouchmi.app.influencer.monthly

VITE_APP_NAME="${APP_NAME}"
