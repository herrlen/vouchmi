# =====================================================
# VOUCHMI .htaccess — Linevast / Apache Config
# =====================================================

# ----- Default Charset
AddDefaultCharset UTF-8

# ----- Directory Index
DirectoryIndex index.html index.php

# ----- Disable directory listing
Options -Indexes

# =====================================================
# HTTPS REDIRECT + WWW WEGLASSEN
# =====================================================
<IfModule mod_rewrite.c>
    RewriteEngine On

    # HTTPS erzwingen
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # WWW entfernen (www.vouchmi.com -> vouchmi.com)
    RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
    RewriteRule ^(.*)$ https://%1/$1 [L,R=301]

    # HTML-Erweiterung aus URLs entfernen (optional, für schönere URLs)
    # Aufruf von /kontakt führt zu /kontakt.html
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.html -f
    RewriteRule ^([^\.]+)$ $1.html [NC,L]
</IfModule>

# =====================================================
# SECURITY HEADERS
# =====================================================
<IfModule mod_headers.c>
    # Schutz vor Clickjacking
    Header always set X-Frame-Options "SAMEORIGIN"

    # Verhindert MIME-Sniffing
    Header always set X-Content-Type-Options "nosniff"

    # Referrer-Policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Permissions Policy (frühere Feature-Policy)
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"

    # HSTS (nach HTTPS-Migration aktivieren — VORSICHT: min. 1 Jahr testen!)
    # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

    # Content-Security-Policy
    # Hinweis: Bei Bedarf um externe Dienste erweitern (z.B. Google Analytics, Meta Pixel)
    Header always set Content-Security-Policy "default-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https:; script-src 'self' 'unsafe-inline'; connect-src 'self'; frame-ancestors 'self';"

    # Verstecke Server-Infos
    Header unset X-Powered-By
    Header unset Server
</IfModule>

# =====================================================
# GZIP KOMPRESSION
# =====================================================
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript
    AddOutputFilterByType DEFLATE application/javascript application/x-javascript application/json
    AddOutputFilterByType DEFLATE application/xml application/rss+xml application/atom+xml
    AddOutputFilterByType DEFLATE image/svg+xml font/ttf font/otf font/woff font/woff2
</IfModule>

# =====================================================
# BROWSER CACHING
# =====================================================
<IfModule mod_expires.c>
    ExpiresActive On

    # HTML -> kurz (1 Stunde), damit Updates schnell sichtbar sind
    ExpiresByType text/html "access plus 1 hour"

    # CSS & JS -> 1 Monat (mit Versionierung via Dateiname ggf. länger)
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"

    # Bilder & Fonts -> 1 Jahr
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/otf "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"

    # Sonstiges -> 1 Woche
    ExpiresDefault "access plus 1 week"
</IfModule>

# =====================================================
# SENSIBLE DATEIEN SCHÜTZEN
# =====================================================
# .htaccess selbst blockieren
<Files ".htaccess">
    Require all denied
</Files>

# Dotfiles (git, env) blockieren
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Newsletter-Datenordner sperren (CSV-Dateien nicht öffentlich zugänglich!)
<IfModule mod_rewrite.c>
    RewriteRule ^newsletter_data/ - [F,L]
    RewriteRule ^rate_limits/ - [F,L]
</IfModule>

# Log-Dateien blockieren
<FilesMatch "\.(log|sql|bak|backup|swp)$">
    Require all denied
</FilesMatch>

# =====================================================
# ERROR PAGES (optional)
# =====================================================
# ErrorDocument 404 /404.html
# ErrorDocument 500 /500.html
