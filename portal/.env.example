# Backend base URL used by Server Components and Server Actions.
#
# Production (Vercel):  BACKEND_URL=https://api.vouchmi.com
# Local dev:            BACKEND_URL=http://localhost:8000
#
# Next.js rewrites in next.config.ts forward /api and /sanctum paths
# from the user-facing origin (app.vouchmi.com) to this backend.
BACKEND_URL=http://localhost:8000

# Public origin of the portal. Used for absolute URL generation
# (OG tags, canonical links, email link templates).
# Production: https://app.vouchmi.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Toggle api mocks during development when a backend endpoint is missing.
NEXT_PUBLIC_USE_MOCKS=false
