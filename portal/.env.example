# Backend base URL used by Server Components and Server Actions.
# In production (same-origin behind Nginx) set to https://app.vouchmi.com
# In development we rewrite /api and /sanctum to localhost:8000 via next.config.ts,
# so BACKEND_URL should match what the Next server itself reaches.
BACKEND_URL=http://localhost:8000

# Public origin of the portal. Used only for absolute URL generation
# (e.g. OG tags, email link generation). No secrets here.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Toggle api mocks during development when a backend endpoint is missing.
NEXT_PUBLIC_USE_MOCKS=false
